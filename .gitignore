/.quarto/

# Reading materials (copyrighted PDFs and markdown transcriptions)
readings/*.pdf
readings/*.md
readings/*.txt

# OS files
.DS_Store
Thumbs.db

# R session files
.Rhistory
.Rdata
.RData
.Ruserdata

# Dataset and student project data (large files, copyrighted content)
data/

# Public Github repo policy: SLIDES ONLY. Everything else (lab data,
# Apps Script templates, R pipeline, reports, methodology snippets,
# per-account data) lives only in the course Drive folder, linked
# from the Moodle space. Don't push it to a public repo.

# Lab artefacts (kept locally, not pushed)
apps_script/
reports/
templates/
data-raw/

# Lab pipeline R scripts (only scripts/pdf_to_md.py stays public)
scripts/*.R
scripts/_*.sh

# Local environment (TikTok API credentials etc.)
.Renviron
.env

